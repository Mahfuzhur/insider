generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x", "debian-openssl-1.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ProjectType {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  order     Int       @default(0)
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Project {
  id                String         @id @default(cuid())
  title             String
  slug              String         @unique
  typeId            String
  type              ProjectType    @relation(fields: [typeId], references: [id])
  location          String?
  areaSqft          Int?
  yearCompleted     Int?
  duration          String?
  rooms             String?        @db.Text // JSON array string e.g. ["Kitchen","Bedroom"]
  shortDescription  String?        @db.Text
  designStyle       String?
  testimonial       String?        @db.Text
  testimonialAuthor String?
  featured          Boolean        @default(false)
  published         Boolean        @default(true)
  order             Int            @default(0)
  images            ProjectImage[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([typeId])
}

model ProjectImage {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  category  String  @default("live") // "3d" | "live"
  alt       String?
  isCover   Boolean @default(false)
  order     Int     @default(0)

  @@index([projectId])
}

model Service {
  id          String  @id @default(cuid())
  title       String
  description  String? @db.Text
  icon        String  @default("ti-armchair")
  order       Int     @default(0)
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteSetting {
  id           Int      @id @default(1)
  brandName    String   @default("INSIDER")
  brandTagline String   @default("Adorn Your World")
  heroLine    String   @default("Adorn your world")
  heroWords   String   @default("residences,workspaces,interiors,commercial")
  heroTagline String   @db.Text
  aboutTitle  String   @default("We craft interiors that feel unmistakably yours")
  aboutBody   String   @db.Text
  email       String   @default("info@insider.com.bd")
  phone       String   @default("+8801733-516028")
  address     String   @default("House 07, Road 1/C, Block L, Banani Chairman Bari, Dhaka-1212")
  facebook    String   @default("https://www.facebook.com/insiderltd")
  logoUrl     String?
  // Scroll-scrubbed hero film: where its frames live, how many there are,
  // scroll length per frame (vh), and the on-screen caption.
  heroFrameDir   String @default("/hero-frames")
  heroFrameCount Int    @default(361)
  heroSpeed      Float  @default(2)
  heroCaption    String @default("The Bedroom")
  // Time ranges of the walkthrough video that should play slowly on
  // scroll (one "mm.ss - mm.ss" range per line); the rest moves fast.
  heroSlowSegments String? @db.Text
  // Conversion sampling densities: frames per video-second captured for
  // slow segments and for the fast travel between them.
  heroSlowFps Float @default(12)
  heroFastFps Float @default(3)
  // Client review video: a YouTube/Vimeo link or a direct video file URL,
  // with an optional pull-quote and attribution.
  reviewVideoUrl String  @default("")
  reviewQuote    String? @db.Text
  reviewAuthor   String  @default("")
  // Selected colour palette id (see src/lib/theme.ts).
  theme       String   @default("ember")
  updatedAt   DateTime @updatedAt
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  videoUrl  String
  quote     String?  @db.Text
  author    String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
